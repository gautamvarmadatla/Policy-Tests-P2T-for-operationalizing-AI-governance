    - log_check
    - config_check
- rule_id: spans-candidates-filtered/sent_0006-32fa91c6
  source:
    doc: spans_candidates_filtered
    citation: v-when-appropriate-its-performance-regarding-specific-person/sent_0006
    span_id: EU_AI_2024_removed/v-when-appropriate-its-performance-regarding-specific-person/sent_0006
  scope:
    actor:
    - provider
    - deployer
    data_domain: []
    context:
    - high-risk
  hazard: automation bias (over-reliance on outputs)
  conditions:
  - when providing the system to the deployer
  - in particular for high-risk AI systems used to provide information or recommendations
  exceptions: []
  requirements:
  - provider must provide the high-risk AI system to the deployer in such a way that
    natural persons remain aware of the possible tendency to automatically rely or
    over-rely on the output produced by the system (automation bias).
  evidence: []
