    - config_check
- rule_id: spans-candidates-filtered/sent_0002-2c6296f1
  source:
    doc: spans_candidates_filtered
    citation: article-12/sent_0002
    span_id: EU_AI_2024_removed/article-12/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: failure to identify situations that may result in system risk or substantial
    modification
  conditions:
  - when events that may indicate a risk or a substantial modification occur
  exceptions: []
  requirements:
  - developer must ensure logging capabilities record events relevant for identifying
    situations that may result in the high-risk AI system presenting a risk or in
    a substantial modification.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Clause mandates logging of vague 'events relevant' without specifying
      identifiable event types or objective verification criteria.
    evidence_signals:
    - log_check
    - config_check
- rule_id: spans-candidates-filtered/sent_0002-7ac5992a
  source:
    doc: spans_candidates_filtered
    citation: article-12/sent_0002
    span_id: EU_AI_2024_removed/article-12/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: inability to perform post-market monitoring
  conditions:
  - to facilitate post-market monitoring referred to in Article 72
  exceptions: []
  requirements:
  - developer must ensure logging capabilities record events relevant for facilitating
    the post-market monitoring referred to in Article 72.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: ‘Relevant events’ are undefined (Article 72 not specified), so no objective
      oracle can verify logs record the required events.
    evidence_signals:
    - log_check
    - config_check
