- rule_id: spans-candidates-filtered/sent_0007-7f31b7b3
  source:
    doc: spans_candidates_filtered
    citation: appropriate-the-necessary-testing-and-reporting-processes-in/sent_0007
    span_id: EU_AI_2024_removed/appropriate-the-necessary-testing-and-reporting-processes-in/sent_0007
  scope:
    actor:
    - org
    data_domain: []
    context:
    - high-risk
  hazard: harm to health
  conditions:
  - throughout the entire lifecycle of the high-risk AI system
  exceptions:
  - only risks which may be reasonably mitigated or eliminated through development
    or design, or provision of adequate technical information
  requirements:
  - org must plan and run a continuous iterative risk management process throughout
    the entire lifecycle of the high-risk AI system, including regular systematic
    review and updating.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Timing ('continuous', 'regular') and 'reasonably mitigated' are vague;
      no specific observable artifacts or thresholds to form an objective pass/fail
      oracle.
    evidence_signals: []
- rule_id: spans-candidates-filtered/sent_0007-398d30b3
