    context:
    - high-risk
  hazard: noncompliance with provider and deployer obligations
  conditions:
  - for high-risk AI systems
  - '"with a view to achieving compliance with the relevant obligations of the provider
    and deployer set out in Section 3"'
  exceptions: []
  requirements:
  - provider must ensure an appropriate type and degree of transparency for the high-risk
    AI system.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Vague 'appropriate type and degree of transparency' lacks measurable criteria
      or artifacts to check; no objective pass/fail oracle specified.
    evidence_signals:
    - io_check
    - config_check
- rule_id: spans-candidates-filtered/sent_0007-2b7d18a4
