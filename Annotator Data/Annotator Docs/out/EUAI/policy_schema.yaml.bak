    - developer
    data_domain: []
    context: []
  hazard: harm to health
  conditions:
  - to address the risks identified pursuant to point (a)
  exceptions: []
  requirements:
  - developer must adopt appropriate and targeted risk management measures designed
    to address the risks identified pursuant to point (a).
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: 'Vague requirement: ''appropriate'' measures referenced to point (a) have
