    - provider
    data_domain: []
    context:
    - high-risk
  hazard: misapplication due to missing input or dataset specifications
  conditions:
  - when appropriate
  - taking into account the intended purpose of the high-risk AI system
  exceptions: []
  requirements:
  - provider must, when appropriate and taking into account the intended purpose of
    the high-risk AI system, provide specifications for the input data and any other
    relevant information about the training, validation and testing data sets used.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: '''When appropriate'' and ''taking into account the intended purpose''
      are subjective; no objective oracle to decide obligation applicability.'
    evidence_signals:
    - data_check
- rule_id: spans-candidates-filtered/sent_0001-75e8b3f8
  source:
    doc: spans_candidates_filtered
    citation: v-when-appropriate-its-performance-regarding-specific-person/sent_0001
    span_id: EU_AI_2024_removed/v-when-appropriate-its-performance-regarding-specific-person/sent_0001
  scope:
    actor:
    - provider
    data_domain: []
    context:
    - high-risk
  hazard: undocumented/pre-determined changes causing non-conformity
  conditions:
  - at the moment of the initial conformity assessment
  exceptions:
  - if any
  requirements:
  - provider must document the changes to the high-risk AI system and its performance
    which were pre-determined by the provider at the moment of the initial conformity
    assessment.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Requires provider to produce documentation of pre-determined changes;
      presence and content can be inspected against assessment records.
    evidence_signals:
