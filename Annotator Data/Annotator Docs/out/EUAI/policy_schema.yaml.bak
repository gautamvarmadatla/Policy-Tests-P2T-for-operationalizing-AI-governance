  source:
    doc: spans_candidates_filtered
    citation: appropriate-the-necessary-testing-and-reporting-processes-in/sent_0010
    span_id: EU_AI_2024_removed/appropriate-the-necessary-testing-and-reporting-processes-in/sent_0010
  scope:
    actor:
    - developer
    data_domain: []
    context:
    - high-risk
  hazard: deployers lacking required information or training
  conditions:
  - when identifying the most appropriate risk management measures
  - where appropriate
  exceptions: []
