    data_domain: []
    context:
    - high-risk
  hazard: decisions based on unverified identification
  conditions:
  - when the system produces an identification
  - for high-risk AI systems referred to in point 1(a) of Annex III
  exceptions:
  - use for law enforcement, migration, border control or asylum where Union or national
    law considers application disproportionate
  requirements:
  - deployer must not take any action or decision based on the identification resulting
    from the system unless that identification has been separately verified and confirmed
    by at least two natural persons.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Logs and I/O can show whether actions occurred only after two distinct
      human verifications, allowing objective pass/fail.
    evidence_signals:
    - log_check
    - io_check
