    actor:
    - developer
    data_domain: []
    context:
    - high-risk
  hazard: unacceptable residual risk
  conditions:
  - when applying the risk management measures referred to in paragraph 2, point (d)
  exceptions: []
  requirements:
  - developer must ensure that the relevant residual risk associated with each hazard,
