  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: harm to health
  conditions:
  - based on analysis of data gathered from the post-market monitoring system
  exceptions: []
  requirements:
  - developer must evaluate other risks possibly arising based on analysis of data
    gathered from the post-market monitoring system.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: No verifiable artifact or objective criterion; 'evaluate other risks'
      is subjective and lacks observable evidence.
