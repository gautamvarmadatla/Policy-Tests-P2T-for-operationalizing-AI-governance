- rule_id: spans-candidates-filtered/sent_0003-81ceb9f7
  source:
    doc: spans_candidates_filtered
    citation: v-when-appropriate-its-performance-regarding-specific-person/sent_0003
    span_id: EU_AI_2024_removed/v-when-appropriate-its-performance-regarding-specific-person/sent_0003
  scope:
    actor:
    - developer
    data_domain: []
    context:
    - high-risk
  hazard: insufficient human oversight
  conditions:
  - for high-risk AI systems
  - during the period in which they are in use
  exceptions: []
  requirements:
  - developer must design and develop high-risk AI systems, including with appropriate
    human-machine interface tools, so that they can be effectively overseen by natural
    persons during the period in which they are in use.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Outcome 'effectively overseen' is vague and lacks measurable pass/fail
      criteria or objective observable predicate.
    evidence_signals:
    - io_check
    - log_check
    - config_check
- rule_id: spans-candidates-filtered/sent_0003-67af1408
  source:
    doc: spans_candidates_filtered
    citation: v-when-appropriate-its-performance-regarding-specific-person/sent_0003
