  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: liability for harm due to non-compliance
  conditions:
  - victim demonstrates one or more entities did not comply with an obligation relevant
    to the harm and a causal link with AI performance is likely
  - court presumes that non-compliance was the cause of the damage
  exceptions: []
  requirements:
  - org must rebut the court's presumption that non-compliance caused the damage when
    the victim demonstrates non-compliance and a likely causal link with AI performance.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Courtroom rebuttal is a legal outcome; no allowed artifact (I/O, logs,
      config, CI, data, repo) provides an objective pass/fail oracle.
    evidence_signals: []
