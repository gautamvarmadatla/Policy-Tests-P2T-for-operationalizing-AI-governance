- rule_id: spans-passthrough-candidates/sent_0001-dbcc600b
  source:
    doc: spans_passthrough_candidates
    citation: 5-provision-with-general-purpose-foundation-models-lmms/5-1-risks-to-be-addressed-when-providing-a-health-care-servi
    span_id: AI in health - WHO_removed/5-provision-with-general-purpose-foundation-models-lmms/5-1-risks-to-be-addressed-when-providing-a-health-care-servi/sent_0001
  scope:
    actor:
    - developer
    data_domain:
    - health
    context:
    - inference
  hazard: unsafe health-care outputs
  conditions:
  - when a user prompts an LMM to generate health-care related outputs
  - when a provider is permitted by the developer to integrate the LMM into a health-care
    application, product or service
  exceptions: []
  requirements:
  - developer shall identify and implement mitigation measures for novel risks introduced
    by the use of a general-purpose foundation model when a user prompts the LMM to
    generate health-care related outputs or when the provider integrates the LMM into
    a health-care application, product or service.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: 'Vague criteria: ''novel risks'' and acceptable mitigations lack objective
      predicates or required artifacts to allow pass/fail verification.'
    evidence_signals:
    - repo_check
    - config_check
