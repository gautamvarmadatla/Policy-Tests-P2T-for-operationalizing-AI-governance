- rule_id: spans-passthrough-candidates/sent_0002-a6ea9b66
  source:
    doc: spans_passthrough_candidates
    citation: gv-6-2-003/sent_0002
    span_id: NIST AI RMF profiles_removed/gv-6-2-003/sent_0002
  scope:
    actor:
    - org
    data_domain:
    - general
    context: []
  hazard: amplified or deferred liability
  conditions: []
  exceptions: []
  requirements:
  - org shall review vendor contracts for clauses that allow arbitrary or capricious
    termination, defer or amplify liability, or permit unauthorized data collection
    by vendors or third parties.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Specific obligation to review vendor contracts for defined clause types;
      verifiable by inspecting contract documents for such language.
    evidence_signals:
    - data_check
- rule_id: spans-passthrough-candidates/sent_0002-04660620
  source:
    doc: spans_passthrough_candidates
    citation: gv-6-2-003/sent_0002
    span_id: NIST AI RMF profiles_removed/gv-6-2-003/sent_0002
  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: service disruption due to arbitrary termination
  conditions:
  - in vendor contracts
  exceptions: []
  requirements:
  - org shall not include arbitrary or capricious termination clauses for critical
    GAI technologies or vendor services in vendor contracts.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Phrase 'arbitrary or capricious' is subjective; no objective pass/fail
      oracle can determine that from contract text alone.
    evidence_signals:
    - repo_check
- rule_id: spans-passthrough-candidates/sent_0002-6850d29b
  source:
    doc: spans_passthrough_candidates
