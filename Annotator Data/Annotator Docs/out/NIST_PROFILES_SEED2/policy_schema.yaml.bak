  scope:
    actor:
    - org
    data_domain:
    - general
    context: []
  hazard: unauthorized data collection by vendors or third parties
  conditions:
  - in vendor contracts
  - that permit secondary data use
  exceptions: []
  requirements:
  - org shall not include non-standard contract terms that amplify or defer liability
    or that permit unauthorized data collection (e.g., secondary data use) in vendor
    contracts.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Vendor contract texts can be inspected for prohibited non-standard liability
