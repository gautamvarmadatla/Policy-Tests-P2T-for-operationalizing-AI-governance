    data_domain: []
    context: []
  hazard: automation bias
  conditions: []
  exceptions: []
  requirements:
  - org shall provide documentation and educational materials that enable stakeholders
    to understand the system's intended uses, how to effectively execute interactions
    with the system, how to interpret system behavior, when and how to override, intervene,
    or interrupt the system, and how to remain aware of the possible tendency to over-rely
    on outputs produced by the system ("automation bias").
  evidence:
  - educational materials
  - system UX
  severity: high
  is_testable: true
  testability:
    reason: Documentation covering the listed topics can be inspected in repositories
      or UIs to confirm required sections exist.
    evidence_signals:
    - repo_check
    - io_check
