- rule_id: spans-passthrough-candidates/sent_0002-423b2d26
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a2-oversight-of-significant-adverse-impacts/sent_0002
  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: deployment of a Sensitive Use without oversight
  conditions:
  - system meets the definition of a Sensitive Use
  exceptions: []
  requirements:
  - org shall report the system to the Office of Responsible AI.
  evidence:
  - impact assessment
  severity: high
  is_testable: true
  testability:
    reason: Clear obligation to report; presence/absence of a submitted report is
      an objective yes/no verifiable in records/logs.
