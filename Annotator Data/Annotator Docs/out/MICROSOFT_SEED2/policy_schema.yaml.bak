    span_id: Microsoft/index/reliability-safety-goals/goal-rs3-ongoing-monitoring-feedback-and-evaluation/sent_0003
  scope:
    actor:
    - org
    data_domain: []
    context:
    - eval
  hazard: failure to perform ongoing evaluation checkpoints
  conditions:
  - evaluations tagged as Ongoing Evaluation Checkpoints in other Goals
  exceptions: []
  requirements:
  - org shall conduct all evaluations tagged as Ongoing Evaluation Checkpoints in
    other Goals on an ongoing basis.
  evidence: []
