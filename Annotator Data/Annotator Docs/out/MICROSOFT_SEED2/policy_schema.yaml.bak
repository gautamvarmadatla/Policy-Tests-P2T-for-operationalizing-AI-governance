    - repo_check
- rule_id: spans-passthrough-candidates/sent_0002-057530b7
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a2-oversight-of-significant-adverse-impacts/sent_0002
  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: deployment of a Sensitive Use without oversight
  conditions: []
  exceptions: []
  requirements:
  - org shall answer prompts in the Impact Assessment template to determine whether
    the system meets the definition of a Sensitive Use.
  evidence:
  - impact assessment
  severity: high
  is_testable: true
  testability:
    reason: Completion of the Impact Assessment prompts is verifiable by inspecting
      the completed template artifact in the org repository/records.
    evidence_signals:
    - repo_check
- rule_id: spans-passthrough-candidates/sent_0003-c5e8c046
  source:
    doc: spans_passthrough_candidates
    span_id: Microsoft/index/accountability-goals/goal-a2-oversight-of-significant-adverse-impacts/sent_0003
    citation: index/accountability-goals
  scope:
    data_domain:
    - general
    context:
    - internal
    actor:
    - org
  hazard: undetected systems that meet Sensitive or Restricted Uses criteria
  conditions:
  - at least annually
  - against the definitions for Sensitive Uses and Restricted Uses
  - If there are systems that meet the criteria for Sensitive Uses
  - If there are systems that meet the criteria for Restricted Uses
  exceptions: []
  requirements:
  - Review your systems at least annually against the definitions for Sensitive Uses
    and Restricted Uses.
  - Report systems that meet the criteria for Sensitive Uses to the Office of Responsible
    AI.
  - Notify the Office of Responsible AI of systems that meet the criteria for Restricted
    Uses.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Annual reviews and reports create auditable records; check policy/config
      and submission/audit logs for required events.
    evidence_signals:
    - config_check
    - log_check
- rule_id: spans-passthrough-candidates/sent_0003-f3dc54d2
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a2-oversight-of-significant-adverse-impacts/sent_0003
  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: failure to notify Office of systems that meet Restricted Uses criteria
  conditions:
  - system meets the criteria for Restricted Uses
  exceptions: []
  requirements:
  - The org must notify the Office of Responsible AI of systems that meet the criteria
    for Restricted Uses.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Requires org to notify Office — verifiable by checking notification logs
      and system metadata for Restricted Uses systems.
    evidence_signals:
    - log_check
    - data_check
- rule_id: spans-passthrough-candidates/sent_0001-851df325
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0001
  scope:
    actor:
    - org
    data_domain: []
    context: []
  hazard: system not fit for intended use
  conditions: []
  exceptions: []
  requirements:
  - org must document in the Impact Assessment how the system's use will solve the
    problem posed by each intended use.
  evidence:
  - impact assessment
  severity: high
  is_testable: true
  testability:
    reason: Requires org to include a per-intended-use explanation in the Impact Assessment;
      presence and mapping can be checked in the document.
    evidence_signals:
    - repo_check
- rule_id: spans-passthrough-candidates/sent_0002-2cf034f8
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: incorrect outputs due to inadequate input representation
  conditions:
  - for each model in the AI system
  exceptions: []
  requirements:
  - developer shall define and document the model's proposed inputs and how well they
    represent the concepts they are intended to represent, including an analysis of
    the limitations of this representation.
  evidence: []
  severity: medium
  is_testable: false
  testability:
    reason: Requires qualitative judgment of 'how well' inputs represent concepts;
      no objective oracle specified to assess adequacy.
    evidence_signals:
    - data_check
- rule_id: spans-passthrough-candidates/sent_0002-660bb048
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: poor generalizability leading to failures on new data
  conditions:
  - for each model in the AI system
  exceptions: []
  requirements:
  - developer shall define and document limitations to the generalizability of the
    resulting model based on the training and testing data that will be used.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Presence of a developer-authored document stating model generalizability
      limitations tied to training/testing data can be objectively checked.
    evidence_signals:
    - repo_check
    - data_check
- rule_id: spans-passthrough-candidates/sent_0002-375562a8
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: release of models unsuited to intended use
  conditions:
  - for this Goal
  exceptions: []
  requirements:
  - developer shall define and document Responsible Release Criteria for this Goal
    that include a concise definition of the problem being solved in the intended
    use, performance metrics and their Responsible Release Criteria, and error types
    and their Responsible Release Criteria.
  evidence:
  - Responsible Release Criteria
  severity: high
  is_testable: true
  testability:
    reason: Obligation to document specific release criteria; presence and content
      can be verified in repository/documentation.
    evidence_signals:
    - repo_check
- rule_id: spans-passthrough-candidates/sent_0002-5692bbd5
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0002
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: undetected failures due to insufficient evaluation
  conditions:
  - for each of the performance metrics and error types
  exceptions: []
  requirements:
  - developer shall document an evaluation plan for each of the performance metrics
    and error types.
  evidence:
  - evaluation plan
  severity: high
  is_testable: false
  testability:
    reason: Cannot verify 'each' metric/error covered because the set of performance
      metrics and error types isn't specified; needs repo/data cross-check.
    evidence_signals:
    - repo_check
    - data_check
- rule_id: spans-passthrough-candidates/sent_0003-725be0ce
  source:
    doc: spans_passthrough_candidates
    citation: index/accountability-goals
    span_id: Microsoft/index/accountability-goals/goal-a3-fit-for-purpose/sent_0003
  scope:
    actor:
    - developer
    data_domain: []
    context: []
  hazard: undetected regressions in system performance
  conditions: []
  exceptions: []
  requirements:
  - developer shall use the methods defined in requirement A3.4 to conduct evaluations.
  evidence: []
  severity: medium
  is_testable: true
  testability:
    reason: Clear obligation to use A3.4 methods; can be verified in repo, evaluation
      artifacts, or runtime logs.
    evidence_signals:
    - repo_check
    - io_check
    - log_check
- rule_id: spans-passthrough-candidates/sent_0003-4bf1db5e
  source:
    doc: spans_passthrough_candidates
