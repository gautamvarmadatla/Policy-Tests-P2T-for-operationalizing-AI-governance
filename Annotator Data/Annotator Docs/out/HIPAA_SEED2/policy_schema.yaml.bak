    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0003
  scope:
    actor:
    - entity
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - permitted or required by this subpart
  - permitted or required by subpart C of part 160 of this subchapter
  exceptions: []
  requirements:
  - Not use or disclose protected health information.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Explicit prohibition against PHI use/disclosure; PHI presence can be detected
      in model I/O, runtime logs, or datasets.
    evidence_signals:
    - io_check
    - log_check
    - data_check
