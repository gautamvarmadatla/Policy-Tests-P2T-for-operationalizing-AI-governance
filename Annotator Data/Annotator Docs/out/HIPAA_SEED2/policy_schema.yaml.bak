      to the Secretary; verifiable via access/transfer logs.
    evidence_signals:
    - log_check
- rule_id: spans-passthrough-candidates/sent_0005-123935db
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0005
  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI retention after contract termination
  conditions:
  - at termination of the contract
  exceptions:
  - if return or destruction of the information is not feasible
  requirements:
  - At termination of the contract, the business associate shall, if feasible, return
    or destroy all protected health information received from, or created or received
    by the business associate on behalf of, the covered entity that the business associate
    still maintains in any form and retain no copies of such information.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Verify no PHI copies remain after contract termination by inspecting storage
      inventories and deletion logs; feasibility exception must be documented.
    evidence_signals:
    - data_check
    - log_check
