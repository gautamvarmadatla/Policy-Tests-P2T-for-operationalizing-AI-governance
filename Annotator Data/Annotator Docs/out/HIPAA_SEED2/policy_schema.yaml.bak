- rule_id: spans-passthrough-candidates/sent_0014-1e3ca17a
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0014
  scope:
    actor:
    - entity
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - has agreed to a restriction pursuant to § 164.522(a)(1)
  exceptions:
  - except as otherwise provided in § 164.522(a)
  requirements:
  - The covered entity must not use or disclose the protected health information covered
    by the restriction in violation of that restriction.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: No objective artifact links specific PHI to the named restriction or records
      prohibited disclosures, so violations cannot be reliably detected.
    evidence_signals:
    - data_check
    - log_check
