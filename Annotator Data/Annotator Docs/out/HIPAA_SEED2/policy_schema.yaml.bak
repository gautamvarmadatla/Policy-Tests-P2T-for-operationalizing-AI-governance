    - log_check
    - config_check
- rule_id: spans-passthrough-candidates/sent_0005-7be083e7
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0005
  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: noncompliance with applicable PHI requirements and impaired regulatory review
  conditions:
  - to the extent the business associate is to carry out a covered entity's obligation
    under this subpart
  - for purposes of determining the covered entity's compliance with this subpart
  exceptions: []
  requirements:
  - The business associate shall, to the extent it is to carry out a covered entity's
    obligation under this subpart, comply with the requirements of this subpart that
    apply to the covered entity in the performance of such obligation and make its
    internal practices, books, and records relating to the use and disclosure of protected
    health information available to the Secretary for purposes of determining the
    covered entity's compliance with this subpart.
