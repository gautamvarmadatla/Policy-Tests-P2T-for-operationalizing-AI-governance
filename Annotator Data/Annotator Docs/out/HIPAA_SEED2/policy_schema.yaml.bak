    - log_check
- rule_id: spans-passthrough-candidates/sent_0012-5d6092db
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0012
  scope:
    actor:
    - entity
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - Actual knowledge that the reproductive health care was not lawful under the circumstances
    in which it was provided.
  exceptions: []
  requirements:
  - Entity or business associate must not treat reproductive health care provided
    by another person as presumed lawful when they have actual knowledge that the
    reproductive health care was not lawful under the circumstances in which it was
    provided.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Requires proving subjective legal states ('actual knowledge' and 'not
      lawful') that cannot be objectively checked from artifacts alone.
    evidence_signals:
    - log_check
    - io_check
- rule_id: spans-passthrough-candidates/sent_0013-53562974
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0013
  scope:
    actor:
    - entity
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: excessive disclosure of PHI
  conditions:
  - when using or disclosing protected health information
  exceptions: []
  requirements:
  - entity or business associate must make reasonable efforts to limit protected health
    information to the minimum necessary when using or disclosing protected health
    information.
  evidence: []
