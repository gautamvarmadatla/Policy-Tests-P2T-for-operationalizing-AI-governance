- rule_id: spans-passthrough-candidates/sent_0005-d5235543
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0005
  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - in a manner that would violate the requirements of this subpart if done by the
    covered entity
  exceptions:
  - except for the purposes specified under § 164.504(e)(2)(i)(A) or (B) if such uses
    or disclosures are permitted by its contract or other arrangement
  requirements:
  - business associate shall not use or disclose protected health information in a
    manner that would violate the requirements of this subpart if done by the covered
    entity.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Can be checked by inspecting model I/O/logs for PHI disclosures and contracts/config
      for permitted exceptions under §164.504(e)(2).
    evidence_signals:
    - io_check
    - log_check
    - config_check
