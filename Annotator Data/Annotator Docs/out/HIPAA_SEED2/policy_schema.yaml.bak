  scope:
    actor:
    - entity
    data_domain:
    - PHI
    context: []
  hazard: undisclosed financial remuneration in marketing authorizations
  conditions:
  - marketing involves financial remuneration to the covered entity from a third party
  exceptions: []
  requirements:
  - entity must state in the authorization that such remuneration is involved when
    the marketing involves financial remuneration to the covered entity from a third
    party.
  evidence:
  - authorization
  severity: high
  is_testable: true
  testability:
    reason: Obligates entities to disclose third-party financial remuneration in authorizations;
      verifiable by inspecting the authorization text (I/O).
    evidence_signals:
    - io_check
