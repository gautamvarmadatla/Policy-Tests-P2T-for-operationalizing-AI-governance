- rule_id: spans-passthrough-candidates/sent_0006-d63b03e0
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-502-uses-and-disclosures-of-protected-health-information/sent_0006
  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: denial of individual's electronic access to PHI
  conditions:
  - individual's request for an electronic copy of protected health information
  - as necessary to satisfy a covered entity's obligations under § 164.524(c)(2)(ii)
    and (3)(ii)
  exceptions: []
  requirements:
  - The business associate shall disclose protected health information to the covered
    entity, individual, or the individual's designee as necessary to satisfy a covered
    entity's obligations under § 164.524(c)(2)(ii) and (3)(ii) with respect to an
    individual's request for an electronic copy of protected health information.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Obligation for business associate to disclose PHI on an individual's electronic-copy
      request; verifiable by inspecting request/response I/O or disclosure logs.
    evidence_signals:
    - io_check
    - log_check
- rule_id: spans-passthrough-candidates/sent_0006-6d40e858
  source:
