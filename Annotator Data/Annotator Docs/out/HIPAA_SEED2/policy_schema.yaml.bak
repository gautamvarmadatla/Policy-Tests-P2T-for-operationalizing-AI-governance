- rule_id: spans-passthrough-candidates/sent_0012-09279063
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-508-uses-and-disclosures-for-which-an-authorization-is-r
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-508-uses-and-disclosures-for-which-an-authorization-is-r/sent_0012
  scope:
    actor:
    - provider
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - revocation is in writing
  - authorization was obtained as a condition of obtaining insurance coverage
  - other law provides the insurer with the right to contest a claim under the policy
    or the policy itself
  exceptions: []
  requirements:
  - provider shall not treat a written revocation of authorization as effective to
    the extent the authorization was obtained as a condition of obtaining insurance
    coverage and other law provides the insurer the right to contest a claim under
    the policy or the policy itself.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Needs evidence of legal preconditions and provider handling; no specified
      logs, inputs, or metadata to verify objectively.
    evidence_signals:
