  scope:
    actor:
    - org
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - workforce member is the victim of a criminal act
  - disclosure to a law enforcement official
  - PHI disclosed is about the suspected perpetrator
  - PHI disclosed is limited to the information listed in § 164.512(f)(2)(i)
  exceptions: []
  requirements:
  - org shall treat a disclosure of protected health information by a workforce member
    who is the victim of a criminal act to a law enforcement official as not a violation
    of this subpart when the disclosed PHI is about the suspected perpetrator and
    is limited to the information listed in § 164.512(f)(2)(i).
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Clear obligation with specific actor/conditions; verifiable by inspecting
      disclosures, org policy, or audit logs against allowed fields list.
    evidence_signals:
    - io_check
    - config_check
    - log_check
