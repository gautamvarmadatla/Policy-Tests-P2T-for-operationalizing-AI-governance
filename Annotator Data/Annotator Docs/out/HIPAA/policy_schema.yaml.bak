  scope:
    actor:
    - entity
    data_domain:
    - PHI
    context: []
  hazard: sale of PHI without authorization
  conditions:
  - disclosure is a sale of protected health information as defined in § 164.501
  exceptions: []
  requirements:
  - Entity must obtain an authorization for any disclosure of protected health information
    which is a sale of protected health information.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Obligation to obtain authorization for any PHI sale can be verified by
      correlating disclosure events with authorization records in logs/metadata.
    evidence_signals:
    - log_check
    - data_check
