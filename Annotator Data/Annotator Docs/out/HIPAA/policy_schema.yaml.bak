  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: improper retention or further use of PHI after contract termination
  conditions:
  - at termination of the contract
  - if feasible
  exceptions:
  - if return or destruction is not feasible, extend the protections of the contract
    to the information and limit further uses and disclosures to those purposes that
    make the return or destruction of the information infeasible
  requirements:
  - At termination of the contract, if feasible, return or destroy all protected health
    information received from, or created or received by the business associate on
    behalf of, the covered entity that the business associate still maintains in any
    form and retain no copies of such information.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Business associate must delete/return PHI at termination — verifiable
      by deletion logs, storage inventories, and retention/config settings.
    evidence_signals:
    - log_check
    - data_check
    - config_check
