    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-508-uses-and-disclosures-for-which-an-authorization-is-r/sent_0010
  scope:
    actor:
    - entity
    data_domain:
    - PHI
    context: []
  hazard: unauthorized disclosure of psychotherapy notes
  conditions:
  - authorization is for a use or disclosure of psychotherapy notes
  exceptions: []
  requirements:
  - entity must not combine an authorization for a use or disclosure of psychotherapy
    notes with an authorization that is not for a use or disclosure of psychotherapy
    notes.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Check authorization records/forms to ensure no single authorization contains
      psychotherapy-notes plus other-use authorization.
