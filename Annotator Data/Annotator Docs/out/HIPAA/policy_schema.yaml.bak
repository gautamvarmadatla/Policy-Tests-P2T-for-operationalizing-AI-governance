- rule_id: spans-passthrough-candidates/sent_0011-497dbe8d
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0011
  scope:
    actor:
    - org
    data_domain:
    - PHI
    context: []
  hazard: inconsistent PHI disclosures
  conditions: []
  exceptions: []
  requirements:
  - Amend the plan documents of the group health plan to incorporate provisions that
    establish the permitted and required uses and disclosures of protected health
    information by the plan sponsor, ensuring those uses and disclosures are not inconsistent
    with this subpart.
  evidence: []
  severity: high
  is_testable: false
