    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0007
  scope:
    actor:
    - entity
    data_domain: []
    context: []
  hazard: business associate non-compliance with required assurances
  conditions:
  - as required by paragraph (e)(2) of this section and § 164.314(a)(1), if applicable
  exceptions: []
  requirements:
  - The covered entity shall attempt in good faith to obtain satisfactory assurances
    as required by paragraph (e)(2) of this section and § 164.314(a)(1), if applicable.
  evidence: []
  severity: high
  is_testable: false
  testability:
    reason: Vague 'good faith' and 'satisfactory assurances' are subjective; requires
      documented contracts/assurances (repo_check or data_check) to verify.
    evidence_signals:
    - repo_check
    - data_check
- rule_id: spans-passthrough-candidates/sent_0007-094ed590
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0007
  scope:
    actor:
    - entity
    data_domain: []
    context: []
  hazard: business associate non-compliance with required assurances
  conditions:
  - if such attempt to obtain satisfactory assurances fails
  exceptions: []
  requirements:
  - If the attempt to obtain satisfactory assurances fails, the covered entity shall
    document the attempt and the reasons that such assurances cannot be obtained.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Mandates documenting failed assurance attempts and reasons; existence
      of such records can be verified via logs.
    evidence_signals:
    - log_check
- rule_id: spans-passthrough-candidates/sent_0008-13b75f32
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-504-uses-and-disclosures-organizational-requirements/sent_0008
  scope:
    actor:
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure to subcontractors
  conditions:
  - contract or other arrangement required by § 164.502(e)(1)(ii) between a business
    associate and a business associate that is a subcontractor
  exceptions: []
  requirements:
  - Include in any contract or other arrangement required by § 164.502(e)(1)(ii) between
    a business associate and a business associate that is a subcontractor the requirements
    of § 164.504(e)(2) through § 164.504(e)(4) in the same manner as they apply to
    contracts or other arrangements between a covered entity and a business associate.
  evidence: []
  severity: high
  is_testable: true
  testability:
    reason: Verify contracts or contract-templates include §164.504(e)(2)–(e)(4) language
      by inspecting stored agreement documents or templates.
    evidence_signals:
    - repo_check
    - config_check
- rule_id: spans-passthrough-candidates/sent_0010-9443443e
  source:
