- rule_id: spans-passthrough-candidates/sent_0003-be15789d
  source:
    doc: spans_passthrough_candidates
    citation: subpart-e-privacy-of-individually-identifiable-health-inform/164-509-uses-and-disclosures-for-which-an-attestation-is-req
    span_id: HIPAA_removed/subpart-e-privacy-of-individually-identifiable-health-inform/164-509-uses-and-disclosures-for-which-an-attestation-is-req/sent_0003
  scope:
    actor:
    - entity
    - business associate
    data_domain:
    - PHI
    context: []
  hazard: unauthorized PHI disclosure
  conditions:
  - for purposes specified in § 164.512(d), (e), (f), or (g)(1)
  - without obtaining an attestation that is valid under paragraph (b)(1) from the
    person requesting the use or disclosure
  - not complying with all applicable conditions of this part
  exceptions: []
  requirements:
  - entity and business associate must not use or disclose protected health information
    potentially related to reproductive health care for purposes specified in § 164.512(d),
    (e), (f), or (g)(1) without obtaining an attestation that is valid under paragraph
    (b)(1) from the person requesting the use or disclosure and without complying
    with all applicable conditions of this part.
  evidence:
  - attestation
  severity: high
  is_testable: true
  testability:
    reason: Check disclosure events, verify existence/validity of requester attestation,
      and confirm applicable-condition compliance via logs, attestation records, and
      configs.
    evidence_signals:
    - log_check
    - data_check
    - config_check
